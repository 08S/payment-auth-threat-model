NODE_ENV=development
PORT=3000
ISSUER=http://localhost:3000
AUDIENCE=payment-api
SESSION_SECRET=replace-with-at-least-64-random-characters-before-production
DEMO_CLIENT_ID=payment-web
DEMO_REDIRECT_URI=http://localhost:5173/callback
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=1209600

# Required when NODE_ENV=production. Use a private/public RSA key pair from KMS,
# a secrets manager, or a secured deployment secret.
# JWT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
